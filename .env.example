# ════════════════════════════════════════════════════════════════
# Environment variables — copy to .env.local and fill in the values
#
#   cp .env.example .env.local
#
# In Vercel: Project → Settings → Environment Variables
# Source of truth for required/optional: src/lib/env.ts
# ════════════════════════════════════════════════════════════════

# ── REQUIRED — the app will not start without these ─────────────
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. NEVER expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# ── OPTIONAL — the app degrades gracefully without these ────────
# Google Cloud Console → Maps JavaScript API (map shows placeholder if unset)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Canonical site URL for SEO/sitemap, WITHOUT trailing slash
# (e.g. https://www.casaseisinmobiliaria.com)
NEXT_PUBLIC_SITE_URL=

# Upstash Redis for rate limiting (falls back to in-memory Map if unset)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend for the contact form (form only logs if unset)
RESEND_API_KEY=

# Shared secret for POST /api/revalidate (endpoint is open if unset)
REVALIDATION_SECRET=
